<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
    <!-- See https://aka.ms/maui-publish-app-store#add-entitlements for more information about adding entitlements.-->
    <dict>
        <!-- App Sandbox is off: this is a local dev/export tool that needs unrestricted read/write access
             to arbitrary paths the user picks (game build folders, export destinations), not a Mac App
             Store app. Sandbox without the file-access entitlements is what caused the file picker to
             hang the whole window. Re-enable with the user-selected file entitlements if this ever needs
             to be App Store-distributed. -->
        <key>com.apple.security.app-sandbox</key>
        <false/>
        <key>com.apple.security.network.client</key>
        <true/>
    </dict>
</plist>

