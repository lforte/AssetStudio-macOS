<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AssetStudio.Maui"
             x:Class="AssetStudio.Maui.MainPage"
             Title="AssetStudio"
             BackgroundColor="White">

    <ContentPage.Resources>
        <ResourceDictionary>
            <local:DoubleToGridLengthConverter x:Key="D2G" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <HorizontalStackLayout Grid.Row="0" Padding="10" Spacing="10">
            <Button x:Name="OpenFilesButton" Text="Open File(s)" Clicked="OnOpenFilesClicked" />
            <Button x:Name="ExportSelectedButton" Text="Export Selected" Clicked="OnExportSelectedClicked" IsEnabled="False" />
            <Button x:Name="ExportAllButton" Text="Export All" Clicked="OnExportAllClicked" IsEnabled="False" />
            <SearchBar x:Name="AssetSearchBar" Placeholder="Filter assets..." TextColor="LightGray" TextChanged="OnSearchTextChanged" WidthRequest="250" />
        </HorizontalStackLayout>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ListColumn" Width="450" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*">

                <!-- Tabs that swap the panel below between Scene Hierarchy / Asset List / Asset Classes -->
                <HorizontalStackLayout Grid.Row="0" BackgroundColor="#DDDDDD" Spacing="0">
                    <Button x:Name="SceneHierarchyTabButton" Text="Scene Hierarchy" Clicked="OnSceneHierarchyTabClicked" BackgroundColor="Transparent" TextColor="Black" CornerRadius="0" />
                    <Button x:Name="AssetListTabButton" Text="Asset List" Clicked="OnAssetListTabClicked" BackgroundColor="#BBBBBB" TextColor="Black" CornerRadius="0" />
                    <Button x:Name="AssetClassesTabButton" Text="Asset Classes" Clicked="OnAssetClassesTabClicked" BackgroundColor="Transparent" TextColor="Black" CornerRadius="0" />
                </HorizontalStackLayout>

                <!-- Asset List column headers (only meaningful while that tab is active) -->
                <Grid x:Name="AssetListHeaderRow" Grid.Row="1" Padding="10,6" BackgroundColor="#EEEEEE" ColumnSpacing="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="{Binding Source={x:Static local:AssetListColumnWidths.Instance}, Path=Container, Converter={StaticResource D2G}}" />
                        <ColumnDefinition Width="{Binding Source={x:Static local:AssetListColumnWidths.Instance}, Path=Type, Converter={StaticResource D2G}}" />
                        <ColumnDefinition Width="{Binding Source={x:Static local:AssetListColumnWidths.Instance}, Path=PathID, Converter={StaticResource D2G}}" />
                        <ColumnDefinition Width="{Binding Source={x:Static local:AssetListColumnWidths.Instance}, Path=Size, Converter={StaticResource D2G}}" />
                    </Grid.ColumnDefinitions>

                    <Label x:Name="NameHeaderLabel" Grid.Column="0" Text="Name" FontAttributes="Bold" TextColor="Black">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNameHeaderTapped" />
                        </Label.GestureRecognizers>
                    </Label>

                    <Label x:Name="ContainerHeaderLabel" Grid.Column="1" Text="Container" FontAttributes="Bold" FontSize="12" TextColor="Black" VerticalOptions="Center" Margin="4,0,0,0">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnContainerHeaderTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                    <BoxView Grid.Column="1" Color="#AAAAAA" WidthRequest="1" HorizontalOptions="Start" VerticalOptions="Fill" />
                    <BoxView Grid.Column="1" Color="Transparent" WidthRequest="8" HorizontalOptions="End">
                        <BoxView.GestureRecognizers>
                            <PanGestureRecognizer PanUpdated="OnContainerColumnPanUpdated" />
                        </BoxView.GestureRecognizers>
                    </BoxView>

                    <Label x:Name="TypeHeaderLabel" Grid.Column="2" Text="Type" FontAttributes="Bold" FontSize="12" TextColor="Black" VerticalOptions="Center" Margin="4,0,0,0">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTypeHeaderTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                    <BoxView Grid.Column="2" Color="#AAAAAA" WidthRequest="1" HorizontalOptions="Start" VerticalOptions="Fill" />
                    <BoxView Grid.Column="2" Color="Transparent" WidthRequest="8" HorizontalOptions="End">
                        <BoxView.GestureRecognizers>
                            <PanGestureRecognizer PanUpdated="OnTypeColumnPanUpdated" />
                        </BoxView.GestureRecognizers>
                    </BoxView>

                    <Label x:Name="PathIdHeaderLabel" Grid.Column="3" Text="PathID" FontAttributes="Bold" FontSize="12" TextColor="Black" VerticalOptions="Center" Margin="4,0,0,0">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPathIdHeaderTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                    <BoxView Grid.Column="3" Color="#AAAAAA" WidthRequest="1" HorizontalOptions="Start" VerticalOptions="Fill" />
                    <BoxView Grid.Column="3" Color="Transparent" WidthRequest="8" HorizontalOptions="End">
                        <BoxView.GestureRecognizers>
                            <PanGestureRecognizer PanUpdated="OnPathIdColumnPanUpdated" />
                        </BoxView.GestureRecognizers>
                    </BoxView>

                    <Label x:Name="SizeHeaderLabel" Grid.Column="4" Text="Size" FontAttributes="Bold" FontSize="12" TextColor="Black" VerticalOptions="Center" Margin="4,0,0,0">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSizeHeaderTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                    <BoxView Grid.Column="4" Color="#AAAAAA" WidthRequest="1" HorizontalOptions="Start" VerticalOptions="Fill" />
                    <BoxView Grid.Column="4" Color="Transparent" WidthRequest="8" HorizontalOptions="End">
                        <BoxView.GestureRecognizers>
                            <PanGestureRecognizer PanUpdated="OnSizeColumnPanUpdated" />
                        </BoxView.GestureRecognizers>
                    </BoxView>
                </Grid>

                <!-- Asset Classes column headers -->
                <Grid x:Name="AssetClassesHeaderRow" Grid.Row="1" ColumnDefinitions="*,70" Padding="10,6" BackgroundColor="#EEEEEE" IsVisible="False">
                    <Label Grid.Column="0" Text="Name" FontAttributes="Bold" TextColor="Black" />
                    <Label Grid.Column="1" Text="ID" FontAttributes="Bold" FontSize="12" TextColor="Black" VerticalOptions="Center" />
                </Grid>

                <Grid Grid.Row="2">

                    <CollectionView x:Name="AssetListView" SelectionMode="Single" SelectionChanged="OnAssetSelected">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="10,6" ColumnSpacing="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="{Binding Source={x:Static local:AssetListColumnWidths.Instance}, Path=Container, Converter={StaticResource D2G}}" />
                                        <ColumnDefinition Width="{Binding Source={x:Static local:AssetListColumnWidths.Instance}, Path=Type, Converter={StaticResource D2G}}" />
                                        <ColumnDefinition Width="{Binding Source={x:Static local:AssetListColumnWidths.Instance}, Path=PathID, Converter={StaticResource D2G}}" />
                                        <ColumnDefinition Width="{Binding Source={x:Static local:AssetListColumnWidths.Instance}, Path=Size, Converter={StaticResource D2G}}" />
                                    </Grid.ColumnDefinitions>

                                    <Label Grid.Column="0" Text="{Binding Text}" TextColor="Black" LineBreakMode="TailTruncation" />
                                    <Label Grid.Column="1" Text="{Binding Container}" TextColor="Gray" FontSize="12" VerticalOptions="Center" LineBreakMode="TailTruncation" Margin="4,0,0,0" />
                                    <BoxView Grid.Column="1" Color="#DDDDDD" WidthRequest="1" HorizontalOptions="Start" VerticalOptions="Fill" />
                                    <Label Grid.Column="2" Text="{Binding TypeString}" TextColor="Gray" FontSize="12" VerticalOptions="Center" LineBreakMode="TailTruncation" Margin="4,0,0,0" />
                                    <BoxView Grid.Column="2" Color="#DDDDDD" WidthRequest="1" HorizontalOptions="Start" VerticalOptions="Fill" />
                                    <Label Grid.Column="3" Text="{Binding m_PathID}" TextColor="Gray" FontSize="12" VerticalOptions="Center" Margin="4,0,0,0" />
                                    <BoxView Grid.Column="3" Color="#DDDDDD" WidthRequest="1" HorizontalOptions="Start" VerticalOptions="Fill" />
                                    <Label Grid.Column="4" Text="{Binding FullSize}" TextColor="Gray" FontSize="12" VerticalOptions="Center" Margin="4,0,0,0" />
                                    <BoxView Grid.Column="4" Color="#DDDDDD" WidthRequest="1" HorizontalOptions="Start" VerticalOptions="Fill" />
                                    <BoxView Grid.ColumnSpan="5" Color="#DDDDDD" HeightRequest="1" VerticalOptions="End" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <CollectionView x:Name="SceneHierarchyListView" SelectionMode="Single" SelectionChanged="OnSceneTreeRowSelected" IsVisible="False">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="4,6" ColumnSpacing="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding Indent, Converter={StaticResource D2G}}" />
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Label Grid.Column="1" Text="{Binding ExpanderGlyph}" TextColor="Gray" FontSize="12" VerticalOptions="Center" />
                                    <Label Grid.Column="2" Text="{Binding Node.Text}" TextColor="Black" LineBreakMode="TailTruncation" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <CollectionView x:Name="AssetClassesListView" SelectionMode="Single" SelectionChanged="OnAssetClassSelected" IsVisible="False">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="10,6" ColumnDefinitions="*,70">
                                    <Label Grid.Column="0" Text="{Binding Text}" TextColor="Black" LineBreakMode="TailTruncation" />
                                    <Label Grid.Column="1" Text="{Binding TypeID}" TextColor="Gray" FontSize="12" VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </Grid>

            </Grid>

            <!-- Drag handle to resize the asset list panel -->
            <BoxView Grid.Column="1" Color="LightGray" WidthRequest="1" HorizontalOptions="Center" VerticalOptions="Fill" InputTransparent="False" />
            <BoxView Grid.Column="1" Color="Transparent" InputTransparent="False">
                <BoxView.GestureRecognizers>
                    <PanGestureRecognizer PanUpdated="OnSplitterPanUpdated" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <Grid Grid.Column="2" RowDefinitions="Auto,*">

                <HorizontalStackLayout Grid.Row="0" BackgroundColor="#DDDDDD" Spacing="0">
                    <Button x:Name="VisualPreviewTabButton" Text="Visual Preview" Clicked="OnVisualPreviewTabClicked" BackgroundColor="#BBBBBB" TextColor="Black" CornerRadius="0" />
                    <Button x:Name="DumpTabButton" Text="Dump" Clicked="OnDumpTabClicked" BackgroundColor="Transparent" TextColor="Black" CornerRadius="0" />
                </HorizontalStackLayout>

                <Grid Grid.Row="1">

                    <Grid x:Name="VisualPreviewPanel">
                        <ScrollView x:Name="ImagePreviewScroll" Padding="10">
                            <Grid x:Name="ImagePreviewContainer">
                                <Image x:Name="PreviewImage" Aspect="AspectFit" IsVisible="False" />
                            </Grid>
                        </ScrollView>

                        <Image x:Name="FallbackPreviewImage" Source="preview.png" Aspect="AspectFit" IsVisible="False" />

                        <WebView x:Name="MeshPreviewWebView" IsVisible="False" />

                        <VerticalStackLayout x:Name="AudioPlayerPanel" IsVisible="False" HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
                            <Label x:Name="AudioClipNameLabel" FontSize="18" TextColor="Black" HorizontalOptions="Center" />
                            <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Button x:Name="AudioPlayButton" Text="▶ Play" Clicked="OnAudioPlayClicked" />
                                <Button x:Name="AudioStopButton" Text="■ Stop" Clicked="OnAudioStopClicked" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <HorizontalStackLayout HorizontalOptions="End" VerticalOptions="Start" Margin="16" Spacing="8">
                            <Button x:Name="WireframeToggleButton" Text="Wireframe" IsVisible="False" Clicked="OnWireframeToggleClicked" />
                        </HorizontalStackLayout>

                        <HorizontalStackLayout x:Name="ZoomControls" HorizontalOptions="End" VerticalOptions="End" Margin="0,0,16,16" Spacing="8" IsVisible="False">
                            <Button x:Name="ZoomOutButton" Text="−" WidthRequest="36" HeightRequest="36" CornerRadius="18" Padding="0" Clicked="OnZoomOutClicked" />
                            <Button x:Name="ZoomInButton" Text="+" WidthRequest="36" HeightRequest="36" CornerRadius="18" Padding="0" Clicked="OnZoomInClicked" />
                        </HorizontalStackLayout>
                    </Grid>

                    <Editor x:Name="DumpText" TextColor="Black" IsVisible="False" IsReadOnly="True" FontFamily="Courier" />

                </Grid>

            </Grid>

        </Grid>

        <Grid Grid.Row="2" Padding="10" ColumnDefinitions="*,200">
            <Label x:Name="StatusLabel" Grid.Column="0" Text="Ready" TextColor="Black" VerticalOptions="Center" />
            <ProgressBar x:Name="ExportProgressBar" Grid.Column="1" VerticalOptions="Center" />
        </Grid>

    </Grid>

</ContentPage>
